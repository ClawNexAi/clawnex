# ClawNex Configuration
# Copy to .env.local and fill in your values

PORT=5001

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# --- LM Studio (local model inference) ---
LMSTUDIO_FLEET_URL=http://localhost:1234/v1
LMSTUDIO_FLEET_NAME=LM Studio Fleet
LMSTUDIO_MAIN_URL=http://localhost:1234/v1
LMSTUDIO_MAIN_NAME=LM Studio Main

# --- Optional Connectors ---
# Paperclip — agent orchestration platform. Health poll always works; data
# enrichment (dashboard / agents / activity / approvals) requires both
# PAPERCLIP_API_KEY and PAPERCLIP_COMPANY_ID. Without them, the connector
# falls back to /api/health-only visibility.
PAPERCLIP_URL=http://127.0.0.1:3100
# PAPERCLIP_API_KEY=                  # Bearer token — see Paperclip's docs/api/authentication.md
# PAPERCLIP_COMPANY_ID=                # company UUID — required to scope dashboard/agents/activity/approvals fetches
AUTENSA_URL=http://127.0.0.1:4000
AUTENSA_TOKEN=
CLAW3D_URL=http://localhost:3156

# --- Database ---
# Default: ./clawnex.db (post-v0.9 rebrand). For installs upgrading from a
# pre-rebrand sentinel.db, the resolver auto-detects the legacy file and
# uses it transparently — you only need to override this if your data lives
# somewhere non-standard (mounted volume, network path, etc.).
DATABASE_PATH=./clawnex.db

# --- Clawkeeper ---
CLAWKEEPER_SCAN_INTERVAL_MS=3600000

# --- LiteLLM Proxy ---
# Shared secret between ClawNex and LiteLLM (generated by setup.sh)
LITELLM_MASTER_KEY=

# --- Proxy Ingest ---
# Shared secret for /api/proxy/ingest (LiteLLM callbacks)
# Required when RBAC enabled. Generate: openssl rand -hex 32
CLAWNEX_INGEST_SECRET=

# --- Hermes Agent ---
# HERMES_HOME=~/.hermes
# HERMES_WATCHER_INTERVAL_MS=10000
# HERMES_WATCHER_ENABLED=true

# --- RBAC (Role-Based Access Control) ---
# SAFE DEFAULT: operator authentication + role-based permissions are ON.
# First visit prompts to create an admin via /setup. Keep this ON for
# any deployment reachable from a network (VPS, LAN, Docker host, etc.).
RBAC_ENABLED=true
NEXT_PUBLIC_RBAC_ENABLED=true

# First-admin bootstrap secret. Strongly recommended on any
# network-reachable host to prevent remote takeover during the
# setup window. Generate: openssl rand -hex 32
# Pass via URL on first visit: http://your-host:5001/setup?secret=YOUR_SECRET
SETUP_SECRET=

# CSRF HMAC binding key (DAST 2026-05-15 C1). Keys the per-session
# CSRF token (HMAC-SHA256(SESSION_SECRET, session.id)). Required for
# RBAC-on. Generate: openssl rand -hex 32. If unset, the runtime
# derives a stable secret from SETUP_SECRET and logs a one-time
# warning. Rotating this invalidates every existing session's CSRF
# capability — operators stay logged in but mutations 403 until the
# dashboard remounts and pulls a fresh /api/auth/csrf.
SESSION_SECRET=

# AES-256-GCM key for opt-in forensic evidence capture. Generate with:
# openssl rand -hex 32
# Keep this stable across upgrades; rotating it makes existing forensic
# payloads unreadable. Redacted evidence does not depend on this key.
EVIDENCE_ENCRYPTION_KEY=

# --- Local-dev escape hatch (ONLY uncomment for localhost-only dev) ---
# Running with RBAC off on a network-reachable host exposes an
# unauthenticated dashboard with full platform control. The server
# will log a WARN on every boot reminding you the posture is unsafe.
# Only use this on a private dev machine that has no external network
# path. Never use this in Docker, on a VPS, or on any LAN.
# RBAC_ENABLED=false
# NEXT_PUBLIC_RBAC_ENABLED=false

# --- Email (one of three providers — admin can switch via Configuration → Mail) ---
# Get your API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=ClawNex <noreply@yourdomain.com>
# Password reset links expire after this many minutes (default: 30)
# PASSWORD_RESET_EXPIRY_MINUTES=30

# Magic Link sign-in tokens expire after this many minutes (default: 15,
# clamped 1-60). Shorter than the password reset TTL because a magic link
# IS a sign-in credential — stale links are a liability.
# MAGIC_LINK_EXPIRY_MINUTES=15

# Emailit REST API (v0.9.0+) — third option alongside Resend + SMTP.
# Get your key at https://emailit.com. Preferred path is the Mail
# Configuration card (admin-only) — env vars are bootstrap fallback only.
# MAIL_PROVIDER=emailit
# EMAILIT_API_KEY=
# EMAILIT_FROM_EMAIL=ClawNex <noreply@yourdomain.com>

# SMTP (alternative to Resend / Emailit)
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=true
# SMTP_ALLOW_INSECURE=false  # NEVER true in production — strict cert verification

# SESSION_TTL_HOURS=24
# MAX_SESSIONS_PER_OPERATOR=5
# ACCOUNT_LOCKOUT_THRESHOLD=10
# LOGIN_RATE_LIMIT=5
# SESSION_BIND_IP=false

# --- Multi-auth providers (v0.9.0+) ---
# Passkeys + GitHub OAuth in addition to local password.
# Local password remains the break-glass identifier on every account.
#
# WebAuthn relying-party identity. RP ID must be the registrable domain
# (or parent) the dashboard is served from; expectedOrigin is the full
# scheme+host+port the browser will send. Defaults assume http://localhost:5001.
# Production HTTPS deployments behind a custom domain MUST set both.
# AUTH_RP_ID=clawnex.example.com
# AUTH_RP_NAME=ClawNex
# AUTH_EXPECTED_ORIGIN=https://clawnex.example.com
#
# GitHub OAuth bootstrap. These env vars are a fallback only — the
# preferred path is to configure GitHub OAuth via the AUTHENTICATION
# METHODS card in Configuration (admin-only). The provider is OFF by
# default; admin must flip the toggle even when these are set.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:5001/api/auth/github/callback

# --- Provider API Keys ---
# Sourced by litellm/run.py (via .env.local loader) — do NOT hardcode in
# launchd plists or start.sh. As of v0.6.2 these are the only supported
# secret sources for the LiteLLM proxy.
# OPENROUTER_API_KEY=

# --- LiteLLM Proxy Hardening (v0.6.2) ---
# Fail-closed policy when the shield scan pipeline errors. 'block' (default)
# denies the request; set to 'allow' only for non-production environments.
CLAWNEX_ON_SCAN_ERROR=block

# --- Docker Deployment Only ---
# If you're running ClawNex via docker-compose AND have a public FQDN +
# DNS pointing at the host, set this so Caddy can provision a Let's
# Encrypt cert automatically. Leave unset for local dev (Caddy will use
# an internal CA cert for https://localhost).
# CLAWNEX_DOMAIN=your.clawnex.host
