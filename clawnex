#!/bin/bash
# =============================================================================
# clawnex — service management CLI
#
# Subcommands:
#   start                  Start dashboard + LiteLLM
#   stop                   Stop both
#   restart                Stop then start
#   status                 Show running services, ports, health
#   logs [which]           Tail a log file (default: dashboard)
#                          which: dashboard | litellm | watchdog
#   setup                  Re-run setup.sh (overwrites .env.local — see prompt)
#   uninstall              Run scripts/uninstall.sh against this install
#   version                Print ClawNex version
#   help                   This message
#
# Self-locates the install dir from its own path. When called via a symlink
# (e.g. ~/.local/bin/clawnex → ~/clawnex/clawnex), it resolves the symlink so
# the install dir is always the repo root.
# =============================================================================

set -u

# ---- Self-locate INSTALL_DIR -------------------------------------------------
# readlink -f works on Linux. macOS BSD readlink doesn't support -f, so we
# fall back to a manual symlink resolver. Either way, INSTALL_DIR is the
# directory containing this script (after symlink resolution).
_resolve() {
    local src="$1"
    while [ -L "$src" ]; do
        local link
        link="$(readlink "$src")"
        case "$link" in
            /*) src="$link" ;;
            *)  src="$(dirname "$src")/$link" ;;
        esac
    done
    (cd "$(dirname "$src")" && pwd)
}
INSTALL_DIR="$(_resolve "${BASH_SOURCE[0]}")"
cd "$INSTALL_DIR"

# ---- Defaults + .env.local read ---------------------------------------------
DASHBOARD_PORT=5001
LITELLM_PORT=4001
RBAC_ENABLED="false"

if [ -f "$INSTALL_DIR/.env.local" ]; then
    # Pick out only the variables we care about. eval-free parsing.
    while IFS='=' read -r key value; do
        case "$key" in
            PORT)         DASHBOARD_PORT="$value" ;;
            LITELLM_PORT) LITELLM_PORT="$value" ;;
            RBAC_ENABLED) RBAC_ENABLED="$value" ;;
        esac
    done < <(grep -E '^(PORT|LITELLM_PORT|RBAC_ENABLED)=' "$INSTALL_DIR/.env.local")
fi

if [ "$RBAC_ENABLED" = "true" ]; then
    BIND_HOST="0.0.0.0"
else
    BIND_HOST="127.0.0.1"
fi

# ---- Colors ------------------------------------------------------------------
if [ -t 1 ]; then
    GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'
    BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
    GREEN=''; RED=''; YELLOW=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

# ---- Helpers -----------------------------------------------------------------
_pid_on() { lsof -ti :"$1" 2>/dev/null | head -1; }

_health() {
    # health endpoint over HTTP loopback (works regardless of RBAC bind)
    curl -s --max-time 3 "http://127.0.0.1:${DASHBOARD_PORT}/api/health" 2>/dev/null \
        | grep -o '"status":"ok"' || true
}

# ---- Commands ----------------------------------------------------------------
_wait_for_port() {
    # _wait_for_port <port> <pid> [max_seconds=30]
    # Returns 0 if the port becomes LISTEN'd before the deadline; 1 if the
    # process dies first or the deadline expires.
    local port="$1" pid="$2" max="${3:-30}"
    local i
    for ((i=0; i<max*2; i++)); do
        [ -n "$(_pid_on "$port")" ] && return 0
        kill -0 "$pid" 2>/dev/null || return 1
        sleep 0.5
    done
    return 1
}

cmd_start() {
    # Track outcomes for the final status block. Values: "running" | "started"
    # | "failed" | "skipped". "running" = was already up; "started" = we
    # brought it up; "failed" = we tried and it didn't bind.
    local litellm_state="skipped" dashboard_state=""
    local litellm_pid="" dashboard_pid=""

    # ----- LiteLLM ------------------------------------------------------------
    # Optional: only attempt if a venv + config exist. Dashboard works fine
    # without LiteLLM for non-AI panels.
    if [ -x "$INSTALL_DIR/litellm/venv/bin/litellm" ] && [ -f "$INSTALL_DIR/litellm/config.yaml" ]; then
        if [ -n "$(_pid_on $LITELLM_PORT)" ]; then
            litellm_state="running"
            litellm_pid="$(_pid_on $LITELLM_PORT)"
        else
            mkdir -p "$INSTALL_DIR/logs"
            nohup "$INSTALL_DIR/litellm/venv/bin/litellm" \
                --config "$INSTALL_DIR/litellm/config.yaml" \
                --host 127.0.0.1 --port "$LITELLM_PORT" \
                > "$INSTALL_DIR/logs/litellm.log" 2>&1 &
            local _lpid=$!
            if _wait_for_port "$LITELLM_PORT" "$_lpid" 15; then
                litellm_state="started"
                litellm_pid="$_lpid"
            else
                litellm_state="failed"
            fi
        fi
    fi

    # ----- Dashboard ----------------------------------------------------------
    # Prefer Next.js standalone server (.next/standalone/server.js) when the
    # build emitted it AND the postbuild step copied the static + public
    # trees alongside it. Standalone is what next.config.mjs's
    # `output: 'standalone'` produces, and `next start` warns when run on
    # such a build (issue #32). The .next/static check guards against an
    # incomplete build where postbuild didn't run — in that state the
    # standalone server would 404 every CSS/JS asset, so we fall back to
    # `next start` which serves them out of the source tree.
    local _standalone="$INSTALL_DIR/.next/standalone/server.js"
    local _standalone_static="$INSTALL_DIR/.next/standalone/.next/static"
    if [ -n "$(_pid_on $DASHBOARD_PORT)" ]; then
        dashboard_state="running"
        dashboard_pid="$(_pid_on $DASHBOARD_PORT)"
    elif [ -f "$_standalone" ] && [ -d "$_standalone_static" ]; then
        mkdir -p "$INSTALL_DIR/logs"
        PORT="$DASHBOARD_PORT" HOSTNAME="$BIND_HOST" \
            nohup node "$_standalone" \
            > "$INSTALL_DIR/logs/dashboard.log" 2>&1 &
        local _dpid=$!
        if _wait_for_port "$DASHBOARD_PORT" "$_dpid" 30; then
            dashboard_state="started"
            dashboard_pid="$_dpid"
        else
            dashboard_state="failed"
        fi
    elif [ ! -x "$INSTALL_DIR/node_modules/.bin/next" ]; then
        dashboard_state="failed"
    else
        mkdir -p "$INSTALL_DIR/logs"
        nohup "$INSTALL_DIR/node_modules/.bin/next" start \
            -p "$DASHBOARD_PORT" -H "$BIND_HOST" \
            > "$INSTALL_DIR/logs/dashboard.log" 2>&1 &
        local _dpid=$!
        # Next.js can take 5-15s to fully spawn + bind the port. Give it 30s.
        if _wait_for_port "$DASHBOARD_PORT" "$_dpid" 30; then
            dashboard_state="started"
            dashboard_pid="$_dpid"
        else
            dashboard_state="failed"
        fi
    fi

    # ----- Status summary -----------------------------------------------------
    echo ""
    case "$dashboard_state" in
        running)
            echo -e "  ${GREEN}●${NC} Dashboard running   PID $dashboard_pid   $BIND_HOST:$DASHBOARD_PORT  ${DIM}(was already up)${NC}"
            ;;
        started)
            if [ -n "$(_health)" ]; then
                echo -e "  ${GREEN}✓${NC} Dashboard running   PID $dashboard_pid   $BIND_HOST:$DASHBOARD_PORT"
            else
                echo -e "  ${YELLOW}⚠${NC} Dashboard bound port but health endpoint not yet responding (PID $dashboard_pid)"
            fi
            ;;
        failed)
            echo -e "  ${RED}✗${NC} Dashboard could not be started"
            if [ ! -x "$INSTALL_DIR/node_modules/.bin/next" ]; then
                echo -e "    ${DIM}node_modules/.bin/next not found — run: clawnex setup${NC}"
            else
                echo -e "    ${DIM}Last 5 lines of $INSTALL_DIR/logs/dashboard.log:${NC}"
                tail -5 "$INSTALL_DIR/logs/dashboard.log" 2>/dev/null | sed 's/^/      /'
            fi
            ;;
    esac

    case "$litellm_state" in
        running)
            echo -e "  ${GREEN}●${NC} LiteLLM   running   PID $litellm_pid   127.0.0.1:$LITELLM_PORT       ${DIM}(was already up)${NC}"
            ;;
        started)
            echo -e "  ${GREEN}✓${NC} LiteLLM   running   PID $litellm_pid   127.0.0.1:$LITELLM_PORT"
            ;;
        failed)
            echo -e "  ${RED}✗${NC} LiteLLM   could not be started"
            echo -e "    ${DIM}Last 5 lines of $INSTALL_DIR/logs/litellm.log:${NC}"
            tail -5 "$INSTALL_DIR/logs/litellm.log" 2>/dev/null | sed 's/^/      /'
            ;;
        skipped)
            echo -e "  ${DIM}○ LiteLLM   not configured (no venv or config.yaml — skipped)${NC}"
            ;;
    esac

    # ----- Access hint --------------------------------------------------------
    if [ "$dashboard_state" = "running" ] || [ "$dashboard_state" = "started" ]; then
        echo
        echo -e "  Dashboard: ${CYAN}http://${BIND_HOST}:${DASHBOARD_PORT}${NC}"
        if [ "$BIND_HOST" = "127.0.0.1" ]; then
            echo -e "  ${DIM}(localhost-only — SSH-tunnel to access from another host)${NC}"
        fi
    fi

    # Non-zero exit if dashboard failed, so callers / scripts can detect
    [ "$dashboard_state" = "failed" ] && return 1
    return 0
}

cmd_stop() {
    local stopped=0
    for port in "$DASHBOARD_PORT" "$LITELLM_PORT"; do
        local pid
        pid="$(_pid_on "$port")"
        if [ -n "$pid" ]; then
            kill "$pid" 2>/dev/null && echo -e "  ${GREEN}✓${NC} Stopped PID $pid (port $port)" || true
            stopped=1
        fi
    done
    if [ "$stopped" = "0" ]; then
        echo -e "  ${DIM}—${NC} Nothing was running on $DASHBOARD_PORT or $LITELLM_PORT"
    fi
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    local d_pid l_pid
    d_pid="$(_pid_on $DASHBOARD_PORT)"
    l_pid="$(_pid_on $LITELLM_PORT)"

    echo -e "${BOLD}Dashboard${NC}"
    if [ -n "$d_pid" ]; then
        echo -e "  ${GREEN}●${NC} running   PID $d_pid   $BIND_HOST:$DASHBOARD_PORT"
        if [ -n "$(_health)" ]; then
            echo -e "  ${GREEN}✓${NC} health    ok"
        else
            echo -e "  ${YELLOW}⚠${NC} health    no response"
        fi
    else
        echo -e "  ${DIM}○ not running${NC}"
    fi

    echo
    echo -e "${BOLD}LiteLLM${NC}"
    if [ -n "$l_pid" ]; then
        echo -e "  ${GREEN}●${NC} running   PID $l_pid   127.0.0.1:$LITELLM_PORT"
    else
        echo -e "  ${DIM}○ not running${NC}"
    fi

    echo
    echo -e "${BOLD}Config${NC}"
    echo -e "  RBAC:        $RBAC_ENABLED"
    echo -e "  Install dir: $INSTALL_DIR"
    if [ -f "$INSTALL_DIR/package.json" ]; then
        local v
        v="$(node -e "console.log(require('$INSTALL_DIR/package.json').version)" 2>/dev/null || echo unknown)"
        echo -e "  Version:     $v"
    fi
}

cmd_logs() {
    local which="${1:-dashboard}"
    local logfile="$INSTALL_DIR/logs/${which}.log"
    if [ ! -f "$logfile" ]; then
        echo -e "  ${RED}✗${NC} No such log: $logfile"
        echo -e "  Available: $(ls "$INSTALL_DIR/logs" 2>/dev/null | tr '\n' ' ')"
        return 1
    fi
    echo -e "  ${DIM}Tailing $logfile (Ctrl-C to exit)${NC}"
    tail -F "$logfile"
}

cmd_setup() {
    exec bash "$INSTALL_DIR/setup.sh" "$@"
}

cmd_uninstall() {
    exec bash "$INSTALL_DIR/scripts/uninstall.sh" "$INSTALL_DIR"
}

cmd_version() {
    if [ -f "$INSTALL_DIR/package.json" ]; then
        node -e "console.log(require('$INSTALL_DIR/package.json').version)" 2>/dev/null \
            || cat "$INSTALL_DIR/package.json" | grep -o '"version":[^,]*' | cut -d'"' -f4
    else
        echo "unknown"
    fi
}

cmd_help() {
    cat <<EOF
${BOLD}clawnex${NC} — ClawNex service management CLI

${BOLD}Usage:${NC}  clawnex <command> [args]

${BOLD}Commands:${NC}
  start              Start dashboard + LiteLLM
  stop               Stop both
  restart            Stop, wait, then start
  status             Show running services, ports, health
  logs [name]        Tail a log file (dashboard | litellm | watchdog)
  setup              Re-run setup.sh (will prompt before touching .env.local)
  uninstall          Remove this ClawNex install
  version            Print ClawNex version
  help               This message

${BOLD}Install dir:${NC}  $INSTALL_DIR
EOF
}

# ---- Dispatch ----------------------------------------------------------------
case "${1:-help}" in
    start)     shift; cmd_start "$@" ;;
    stop)      shift; cmd_stop "$@" ;;
    restart)   shift; cmd_restart "$@" ;;
    status)    shift; cmd_status "$@" ;;
    logs)      shift; cmd_logs "$@" ;;
    setup)     shift; cmd_setup "$@" ;;
    uninstall) shift; cmd_uninstall "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help|"") cmd_help ;;
    *)
        echo -e "${RED}Unknown command:${NC} $1"
        echo "Run: clawnex help"
        exit 1
        ;;
esac
